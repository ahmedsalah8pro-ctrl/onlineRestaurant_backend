includes:
    - vendor/larastan/larastan/extension.neon
    - phpstan-baseline.neon

parameters:
    level: 9
    paths:
        - app
        - routes
        - database/factories
        - database/seeders
        - tests
    tmpDir: storage/phpstan
    treatPhpDocTypesAsCertain: false
    universalObjectCratesClasses:
        - stdClass
